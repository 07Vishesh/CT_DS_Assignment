# Which LLM provider to use for Q&A, quiz generation, flashcards, and summaries.
# Embeddings/vector search always run locally and don't need either key.
LLM_PROVIDER=anthropic

# --- Anthropic (used if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (used if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=open-ai-secret-key
OPENAI_MODEL=gpt-4o-mini

# --- RAG tuning (sensible defaults, override if you want to experiment) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=4

MAX_UPLOAD_MB=20
